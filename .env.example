# Grocer-E Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# Node.js / Express Server Configuration
# ==========================================
PORT=3001
NODE_ENV=development

# ==========================================
# PostgreSQL Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grocer_e
DB_USER=grocer_user
DB_PASSWORD=your_secure_password_here

# ==========================================
# Redis Cache Configuration
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# API Configuration
# ==========================================
API_VERSION=v1
API_BASE_URL=http://localhost:3001

# Default search radius for nearby stores (in kilometers)
DEFAULT_SEARCH_RADIUS=5

# ==========================================
# Supermarket Chains
# ==========================================
# Enable or disable scraping for specific chains
SCRAPE_SHUFERSAL=true
SCRAPE_RAMI_LEVY=true
SCRAPE_VICTORY=true

# ==========================================
# Scraper Configuration
# ==========================================
# Request timeout for XML feeds (in seconds)
SCRAPER_REQUEST_TIMEOUT=30

# Schedule for automatic scraping (cron format)
# Example: "0 2 * * *" means run at 2:00 AM every day
SCRAPER_CRON_SCHEDULE=0 2 * * *

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=info
LOG_FILE=grocer-e.log
SCRAPER_LOG_FILE=scraper.log

# ==========================================
# Geo-location Configuration
# ==========================================
# Default coordinates for Israel center (used for testing)
DEFAULT_LATITUDE=31.7683
DEFAULT_LONGITUDE=35.2137

# ==========================================
# Security & Authentication
# ==========================================
# For future use with API authentication
API_KEY=
JWT_SECRET=
CORS_ORIGIN=http://localhost:3000

# ==========================================
# External Services (Optional)
# ==========================================
# For future integrations with mapping or notification services
GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ==========================================
# Development & Debugging
# ==========================================
DEBUG=false
VERBOSE_LOGGING=false
